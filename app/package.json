{
  "name": "app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "npx tsx watch src/index.ts",
    "lint:src": "eslint src --ext .ts --max-warnings 0",
    "lint:tests": "eslint tests --ext .ts --max-warnings 0",
    "lint": "npm run lint:src && npm run lint:tests",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "ci": "npm run lint && npm run build && npm run test:ci",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "test:ci": "jest --coverage --ci --runInBand",
    "seed": "npx tsx src/seeders/runner.ts",
    "audit:integrity": "npx tsx src/scripts/integrityAudit.ts",
    "openapi": "ts-node src/scripts/openapi.ts",
    "openapi:html": "npx @redocly/cli build-docs docs/openapi.json -o docs/openapi.html",
    "docs": "npx typedoc --entryPointStrategy Expand src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "24.3.1",
    "@types/redis": "4.0.10",
    "@types/supertest": "6.0.3",
    "depcheck": "1.4.7",
    "eslint": "9.35.0",
    "jest": "30.1.3",
    "mongodb-memory-server": "11.0.1",
    "supertest": "7.1.4",
    "testcontainers": "11.5.1",
    "ts-jest": "29.4.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.42.0"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "cors": "2.8.6",
    "currency-codes-ts": "3.0.0",
    "dotenv": "17.2.2",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.18.0",
    "multer": "2.0.2",
    "redis": "4.6.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "4.1.12"
  }
}
